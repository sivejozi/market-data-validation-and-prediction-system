<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="1" author="Sive">
        <createTable tableName="clean_fx_rates" schemaName="public">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="currency_pair" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="TIMESTAMP(6)">
                <constraints nullable="false"/>
            </column>
            <column name="rate" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="lag1" type="DECIMAL(19,6)"/>
            <column name="rolling_mean7" type="DECIMAL(19,6)"/>
            <column name="rolling_std7" type="DECIMAL(19,6)"/>
            <column name="rate_scaled" type="DECIMAL(19,6)"/>
            <column name="created_at" type="TIMESTAMP(6)"/>
            <column name="updated_at" type="TIMESTAMP(6)"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="Sive">
        <addColumn tableName="clean_fx_rates" schemaName="public">
            <column name="lag7" type="DECIMAL(19,6)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>